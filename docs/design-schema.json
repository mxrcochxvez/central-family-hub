{
  "name": "family-hub-design-schema",
  "version": "1.2.0",
  "principles": [
    "Civic-inspired trust",
    "Event-first layout",
    "Minimal copy",
    "Clear public-service hierarchy",
    "Square municipal geometry"
  ],
  "tokens": {
    "colors": {
      "background": "#f4f7fb",
      "foreground": "#1f2937",
      "muted": "#6b7280",
      "card": "#ffffff",
      "surface": "#eef3f9",
      "border": "#d6e0eb",
      "accent": "#0a4a85",
      "accentDark": "#083a69",
      "accentSoft": "#e7f0fa",
      "successSoft": "#ebf7ef",
      "warningSoft": "#fff3e8",
      "goldRule": "#d9a441"
    },
    "radius": {
      "lg": "0px",
      "md": "0px",
      "sm": "0px",
      "pill": "0px"
    },
    "shadow": {
      "soft": "0 8px 24px rgba(15, 23, 42, 0.06)",
      "hover": "0 12px 28px rgba(15, 23, 42, 0.1)"
    },
    "spacing": {
      "1": "8px",
      "2": "12px",
      "3": "16px",
      "4": "20px",
      "5": "24px",
      "6": "32px"
    }
  },
  "typography": {
    "fontFamily": "Arial, Helvetica, sans-serif",
    "heroTitle": "clamp(32px, 4vw, 46px)",
    "cardTitle": "19px",
    "body": "16px",
    "meta": "14px",
    "eyebrow": "13px"
  },
  "components": {
    "civicBand": {
      "purpose": "Municipal header anchor",
      "style": ["deep blue band", "gold divider rule", "white utility action", "square geometry"]
    },
    "hero": {
      "purpose": "Orientation block, not marketing banner",
      "style": ["blue top rule", "short headline", "brief support line", "small civic stats", "square-edged containers"]
    },
    "filters": {
      "purpose": "Persistent event narrowing",
      "style": ["sticky on desktop", "square form controls", "quiet labels"]
    },
    "eventCard": {
      "purpose": "Scan-friendly event summary",
      "style": ["title first", "square metadata labels", "subtle hover lift", "public-service clarity"]
    },
    "detailCard": {
      "purpose": "Structured event facts",
      "style": ["two-column meta grid", "matching civic card shell", "square corners"]
    }
  }
}
